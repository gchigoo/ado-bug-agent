{
  "name": "ado-bug-agent",
  "version": "0.1.1",
  "description": "Turn Azure DevOps Bugs into durable bug reports and code-backed root-cause analysis drafts.",
  "author": {
    "name": "Gchigoo",
    "email": "stan.guo@mail.ru",
    "url": "https://github.com/Gchigoo"
  },
  "homepage": "https://github.com/Gchigoo/ado-bug-agent",
  "repository": "https://github.com/Gchigoo/ado-bug-agent",
  "license": "MIT",
  "keywords": [
    "azure-devops",
    "bug-analysis",
    "root-cause-analysis",
    "mcp",
    "ado"
  ],
  "mcpServers": {
    "ado-bug-agent": {
      "command": "node",
      "args": [
        "${CLAUDE_PLUGIN_ROOT}/mcp/ado-bug-agent-mcp.js"
      ],
      "env": {
        "AZURE_DEVOPS_ORG_URL": "${AZURE_DEVOPS_ORG_URL}",
        "AZURE_DEVOPS_PAT": "${AZURE_DEVOPS_PAT}"
      }
    }
  }
}
